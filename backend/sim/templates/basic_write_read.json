{
  "description": "Basic write + read back test. Confirms the slave is reachable, writes a single byte and a multi-byte sequence, then reads each back and asserts the expected values.",
  "steps": [
    {"op": "reset"},
    {"op": "scan",        "addr": "0x50", "expect": true},
    {"op": "write_bytes", "addr": "0x50", "reg": "0x00", "data": ["0xA5"]},
    {"op": "read_bytes",  "addr": "0x50", "reg": "0x00", "n": 1, "expect": ["0xA5"]},
    {"op": "write_bytes", "addr": "0x50", "reg": "0x10", "data": ["0x11", "0x22", "0x33"]},
    {"op": "read_bytes",  "addr": "0x50", "reg": "0x10", "n": 3, "expect": ["0x11", "0x22", "0x33"]}
  ]
}
